# Postgres (Neon, Vercel Postgres, etc.). Use the pooled URL for the app on Vercel.
# Use sslmode=verify-full explicitly (avoids pg-connection-string deprecation warnings; same as managed DBs expect).
DATABASE_URL=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=verify-full

# Optional: Neon “direct” URL without pooler — migrations or scripts that need a single long-lived connection.
# DATABASE_URL_UNPOOLED=postgresql://<user>:<password>@<host>:5432/<db>?sslmode=verify-full

# If Vercel injects these, the app also reads POSTGRES_URL / POSTGRES_CONNECTION_STRING (see lib/postgres.ts).

# Legacy (optional): MongoDB is not required for the main persistence layer in this project.
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-url>/?retryWrites=true&w=majority
# MONGODB_DB_NAME=securebiz_ai

GEMINI_API_KEY=your_gemini_api_key

# Optional: force a specific model (e.g. gemini-2.0-flash)
GEMINI_MODEL=

# Local dev: http://localhost:3000
# Production: set https://securebiz.org in Vercel (recommended). If omitted, Vercel’s
# VERCEL_PROJECT_PRODUCTION_URL is used for sitemap/canonicals on production builds.
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Optional: Google Search Console → Ownership → HTML tag (meta name="google-site-verification")
# NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=

# Optional: Organization JSON-LD sameAs (comma-separated profile URLs). Improves brand signals when set.
# NEXT_PUBLIC_ORG_SAME_AS=https://www.linkedin.com/company/your-brand https://x.com/yourbrand

# Optional: security.txt contact (RFC 9116). Defaults to /about if unset.
# SECURITY_CONTACT_EMAIL=security@yourdomain.com
# SECURITY_CONTACT_URL=https://yourdomain.com/security

# Google Tag Manager (default container matches project; override if needed)
NEXT_PUBLIC_GTM_ID=GTM-5F2SKDDX

# GA4 (gtag.js): measurement ID from Analytics → Data streams
# If the same property is also fired from GTM, disable one path to avoid double counting.
NEXT_PUBLIC_GA_MEASUREMENT_ID=G-LMBKNS44HF
# Set to true if GA4 is configured only inside GTM (skips standalone gtag.js → smaller JS on mobile PSI)
# NEXT_PUBLIC_GA_VIA_GTM_ONLY=true

# Sectors to pre-generate at build time (0 = none).
# Example: 10 → ~30 pages (x3 regulations). Requires `seed` + Gemini availability on first hit.
# Higher values improve TTFB for hot URLs; sitemap/RSS use DATABASE_URL when set for last-mod dates and feed items.
PREBUILD_GUIDE_SECTORS=40

# Vercel Cron to generate new guides automatically
CRON_SECRET=your_long_random_secret
CRON_BATCH_LIMIT=30
